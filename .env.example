# Copy this file to .env and fill in values before running ./start.sh
# .env is gitignored and must never be committed

# Postgres database name (default: postgres)
DB_NAME=postgres

# Postgres superuser username (default: postgres)
DB_USER=postgres

# Postgres superuser password — change this for any non-local environment
DB_PASSWORD=changeme

# Debezium topic prefix for CDC topics.
# Topics are emitted as: <TOPIC_PREFIX>.<schema>.<table>
TOPIC_PREFIX=example

# Debezium table scope (comma-separated schema.table entries)
TABLE_INCLUDE_LIST=cd.members,cd.facilities,cd.bookings
